DATABASE_URL="postgresql://user:password@localhost:5432/civitechglobal?schema=public"
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"
PORT=5000
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# Seed Credentials — Super Admin (full access)
ADMIN_EMAIL=superadmin@civitechglobal.com
ADMIN_PASSWORD=SuperAdmin@123
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# Seed Credentials — Admin (limited CRUD access)
DEMO_ADMIN_EMAIL=admin@civitechglobal.com
DEMO_ADMIN_PASSWORD=Admin@123
DEMO_ADMIN_FIRST_NAME=Manager
DEMO_ADMIN_LAST_NAME=Admin

# Seed Credentials — Normal User
USER_EMAIL=user@civitechglobal.com
USER_PASSWORD=User@123
USER_FIRST_NAME=Demo
USER_LAST_NAME=User

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_MODE=polling              # polling or webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ADMIN_USER_IDS=               # comma-separated Telegram user IDs
TELEGRAM_BOT_PORT=4000
